{
  "name": "sarkari-world",
  "version": "1.0.0",
  "description": "",
  "author": "Raushan Kumar <raushansft@gmail.com>",
  "license": "ISC",
  "main": "server.js",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "node ./bin/www",
    "dev1": "nodemon ./bin/www",
    "dev": "nodemon server.js",
    "build:css": "tailwindcss -i ./resources/css/tailwind.css -o ./public/css/app.css --minify",
    "watch:css": "tailwindcss -i ./resources/css/tailwind.css -o ./public/css/app.css --watch",
    "dev:full": "concurrently \"npm run watch:css\" \"npm run dev\"",
    "build": "npm install && npm run build:css",
    "deploy": "pm2 start ecosystem.config.js --env production"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.23",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18"
  },
  "dependencies": {
    "@tailwindcss/cli": "^4.1.18",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "concurrently": "9.2.1",
    "cookie-parser": "~1.4.4",
    "cors": "^2.8.6",
    "debug": "~2.6.9",
    "dotenv": "^17.3.1",
    "express": "5.2.1",
    "http-errors": "~1.6.3",
    "mongoose": "8.21.1",
    "morgan": "^1.10.1",
    "nodemon": "^3.1.14",
    "pug": "^3.0.4",
    "sanitize-html": "^2.17.2",
    "tailwindcss": "3.4.19",
    "winston": "^3.19.0"
  }
}
