doctype html
html(lang="en")
  head
    - const pageTitle = (meta && meta.title) ? meta.title : 'Sarkari World | Latest Government Jobs, Results, Admit Card'
    - const pageDescription = (meta && meta.description) ? meta.description : 'Get latest Sarkari job updates, admit cards, answer keys, and results in one place.'
    - const canonicalUrl = (meta && meta.canonical) ? meta.canonical : ((seo && seo.currentUrl) ? seo.currentUrl : '')
    - const ogType = (meta && meta.ogType) ? meta.ogType : 'website'
    - const ogTitle = (meta && meta.ogTitle) ? meta.ogTitle : pageTitle
    - const ogDescription = (meta && meta.ogDescription) ? meta.ogDescription : pageDescription
    - const ogImage = (meta && meta.ogImage) ? meta.ogImage : ((seo && seo.defaultImage) ? seo.defaultImage : '')
    meta(charset="utf-8")
    meta(name="viewport", content="width=device-width, initial-scale=1")

    title #{pageTitle}
    meta(name="description", content=pageDescription)
    if canonicalUrl
      link(rel="canonical", href=canonicalUrl)

    meta(property="og:type", content=ogType)
    meta(property="og:title", content=ogTitle)
    meta(property="og:description", content=ogDescription)
    if canonicalUrl
      meta(property="og:url", content=canonicalUrl)
    if seo && seo.siteName
      meta(property="og:site_name", content=seo.siteName)
    if ogImage
      meta(property="og:image", content=ogImage)

    meta(name="twitter:card", content="summary_large_image")
    meta(name="twitter:title", content=ogTitle)
    meta(name="twitter:description", content=ogDescription)
    if ogImage
      meta(name="twitter:image", content=ogImage)
    if meta && meta.articlePublishedTime
      meta(property="article:published_time", content=meta.articlePublishedTime)
    if meta && meta.articleModifiedTime
      meta(property="article:modified_time", content=meta.articleModifiedTime)

    link(rel="stylesheet", href="/css/app.css")

    link(rel="icon", type="image/png", href="/favicon-96x96.png", sizes="96x96")
    link(rel="icon", type="image/svg+xml", href="/favicon.svg")
    link(rel="shortcut icon", href="/favicon.ico")
    link(rel="apple-touch-icon", sizes="180x180", href="/apple-touch-icon.png")

    meta(name="apple-mobile-web-app-title", content="Sarkari World")
    link(rel="manifest", href="/site.webmanifest")
    if meta && meta.extraStylesheet
      link(rel="stylesheet", href=meta.extraStylesheet)
    if seoJsonLd
      script(type="application/ld+json").
        !{JSON.stringify(seoJsonLd)}

  body.min-h-screen.flex.flex-col.text-gray-900
    include ../partials/header

    // Main Content
    main.flex-1
      block content

    // Footer
    include ../partials/footer

    // Cookie Consent Banner
    include ../components/cookie-consent

    // Scripts
    script(async src='https://www.instagram.com/embed.js')