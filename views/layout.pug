doctype html
html
  head
    - const pageTitle = (meta && meta.title) ? meta.title : (title || 'Sarkari World')
    - const pageDescription = (meta && meta.description) ? meta.description : 'Latest jobs and results updates on Sarkari World.'
    - const canonicalUrl = (meta && meta.canonical) ? meta.canonical : ((seo && seo.currentUrl) ? seo.currentUrl : '')
    - const robotsContent = (meta && meta.robots) ? meta.robots : 'index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1'
    title= pageTitle
    meta(name='viewport', content='width=device-width, initial-scale=1, viewport-fit=cover')
    meta(name='description', content=pageDescription)
    meta(name='robots', content=robotsContent)
    if canonicalUrl
      link(rel='canonical', href=canonicalUrl)
    meta(property='og:type', content=(meta && meta.ogType) ? meta.ogType : 'website')
    meta(property='og:title', content=(meta && meta.ogTitle) ? meta.ogTitle : pageTitle)
    meta(property='og:description', content=(meta && meta.ogDescription) ? meta.ogDescription : pageDescription)
    if canonicalUrl
      meta(property='og:url', content=canonicalUrl)
    if seo && seo.siteName
      meta(property='og:site_name', content=seo.siteName)
    if seo && seo.defaultImage
      meta(property='og:image', content=(meta && meta.ogImage) ? meta.ogImage : seo.defaultImage)
    meta(name='twitter:card', content='summary_large_image')
    meta(name='twitter:title', content=(meta && meta.ogTitle) ? meta.ogTitle : pageTitle)
    meta(name='twitter:description', content=(meta && meta.ogDescription) ? meta.ogDescription : pageDescription)
    if seo && seo.defaultImage
      meta(name='twitter:image', content=(meta && meta.ogImage) ? meta.ogImage : seo.defaultImage)
    link(rel='stylesheet', href='/stylesheets/style.css')
    if seoJsonLd
      script(type='application/ld+json').
        !{JSON.stringify(seoJsonLd)}
  body
    block content
