extends ../layouts/main

block content
  section.py-12.bg-gradient-to-r.from-blue-50.to-teal-50
    .max-w-4xl.mx-auto.px-4
      h1.text-4xl.font-bold.text-gray-900 Disclaimer
      p.mt-3.text-gray-700 Please read this disclaimer before using Sarkari World.

  section.py-12.bg-white
    .max-w-4xl.mx-auto.px-4.space-y-6
      .rounded-lg.border-l-4.border-red-600.bg-red-50.p-6
        p.text-red-900.font-semibold
          | Sarkari World is an independent portal and is not affiliated with any government authority.

      article
        h2.text-2xl.font-semibold.text-gray-900 General Information
        p.mt-2.text-gray-700
          | We publish updates for informational purposes. Official websites and notifications are the final source of truth.

      article
        h2.text-2xl.font-semibold.text-gray-900 No Guarantee
        p.mt-2.text-gray-700
          | We do not guarantee job selection, ranking, or outcomes of any exam or recruitment process.

      article
        h2.text-2xl.font-semibold.text-gray-900 External Links
        p.mt-2.text-gray-700
          | Third-party links are shared for convenience. We are not responsible for their content or policy changes.