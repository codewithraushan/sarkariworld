extends ../layouts/admin

block content
  section.max-w-6xl.mx-auto.px-4.py-8
    .rounded-2xl.border.border-gray-200.bg-white.p-6.shadow-sm
      if statusMessage
        if actionStatus === 'created' || actionStatus === 'updated' || actionStatus === 'deleted'
          p.mb-4.rounded-lg.bg-green-50.px-3.py-2.text-sm.font-semibold.text-green-700= statusMessage
        else if actionStatus === 'invalid' || actionStatus === 'duplicate'
          p.mb-4.rounded-lg.bg-red-50.px-3.py-2.text-sm.font-semibold.text-red-700= statusMessage

      .flex.flex-col.gap-3(class='md:flex-row md:items-end md:justify-between')
        div
          h1.text-2xl.font-bold.text-slate-900 Subscribed Users
          p.mt-1.text-sm.text-slate-600 Search and filter subscribers by city and state.

        form.w-full(class='md:w-auto' method='GET' action='/admin/users')
          .grid.grid-cols-1.gap-3(class='sm:grid-cols-2 md:grid-cols-4')
            input.w-full.rounded-lg.border.border-slate-300.px-3.py-2.text-sm(name='q' type='text' value=filters.q placeholder='Search name or email')
            input.w-full.rounded-lg.border.border-slate-300.px-3.py-2.text-sm(name='city' type='text' value=filters.city placeholder='City')
            input.w-full.rounded-lg.border.border-slate-300.px-3.py-2.text-sm(name='state' type='text' value=filters.state placeholder='State')
            .flex.gap-2
              button.inline-flex.items-center.justify-center.rounded-lg.bg-blue-600.px-4.py-2.text-sm.font-semibold.text-white.transition(class='hover:bg-blue-700' type='submit') Apply
              a.inline-flex.items-center.justify-center.rounded-lg.bg-slate-200.px-4.py-2.text-sm.font-semibold.text-slate-700.transition(class='hover:bg-slate-300' href='/admin/users') Reset

      .mt-4
        a.inline-flex.items-center.justify-center.rounded-lg.bg-indigo-600.px-4.py-2.text-sm.font-semibold.text-white.transition(class='hover:bg-indigo-700' href='/admin/users/new') Add User

      .mt-6.overflow-x-auto
        if users && users.length
          table.min-w-full.divide-y.divide-slate-200
            thead.bg-slate-50
              tr
                th.px-3.py-2.text-left.text-xs.font-semibold.uppercase.tracking-wide.text-slate-600 Name
                th.px-3.py-2.text-left.text-xs.font-semibold.uppercase.tracking-wide.text-slate-600 Email
                th.px-3.py-2.text-left.text-xs.font-semibold.uppercase.tracking-wide.text-slate-600 Mobile
                th.px-3.py-2.text-left.text-xs.font-semibold.uppercase.tracking-wide.text-slate-600 City
                th.px-3.py-2.text-left.text-xs.font-semibold.uppercase.tracking-wide.text-slate-600 State
                th.px-3.py-2.text-left.text-xs.font-semibold.uppercase.tracking-wide.text-slate-600 Subscribed On
                th.px-3.py-2.text-left.text-xs.font-semibold.uppercase.tracking-wide.text-slate-600 Actions
            tbody.divide-y.divide-slate-100
              each user in users
                tr
                  td.px-3.py-2.text-sm.text-slate-800= user.name || '-'
                  td.px-3.py-2.text-sm.text-slate-700= user.email || '-'
                  td.px-3.py-2.text-sm.text-slate-700= user.mobile || '-'
                  td.px-3.py-2.text-sm.text-slate-700= user.city || '-'
                  td.px-3.py-2.text-sm.text-slate-700= user.state || '-'
                  td.px-3.py-2.text-sm.text-slate-600= user.subscribed_at ? new Date(user.subscribed_at).toLocaleString() : '-'
                  td.px-3.py-2.text-sm
                    .flex.gap-2
                      a.inline-flex.items-center.justify-center.rounded-md.bg-amber-500.px-3.py-1.font-semibold.text-white.transition(class='hover:bg-amber-600' href='/admin/users/edit/' + user._id) Edit
                      form(method='POST' action='/admin/users/delete/' + user._id onsubmit="return confirm('Delete this user?');")
                        button.inline-flex.items-center.justify-center.rounded-md.bg-red-600.px-3.py-1.font-semibold.text-white.transition(class='hover:bg-red-700' type='submit') Delete
        else
          .rounded-lg.border.border-dashed.border-slate-300.bg-slate-50.p-8.text-center
            p.text-slate-600 No subscribed users found for current filters.