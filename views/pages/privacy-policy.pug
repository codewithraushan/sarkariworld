extends ../layouts/main

block content
  section.py-12.bg-gradient-to-r.from-blue-50.to-teal-50
    .max-w-4xl.mx-auto.px-4
      h1.text-4xl.font-bold.text-gray-900 Privacy Policy
      p.mt-3.text-gray-700 This page explains how we collect and use information.

  section.py-12.bg-white
    .max-w-4xl.mx-auto.px-4.space-y-6
      article
        h2.text-2xl.font-semibold.text-gray-900 Information We Collect
        p.mt-2.text-gray-700
          | We may collect basic usage data, contact information shared by users, and browser metadata.

      article
        h2.text-2xl.font-semibold.text-gray-900 How We Use Data
        p.mt-2.text-gray-700
          | Data is used to improve site performance, respond to support requests, and maintain platform security.

      article
        h2.text-2xl.font-semibold.text-gray-900 Cookies
        p.mt-2.text-gray-700
          | We may use cookies for essential functionality and analytics. You can control cookies from your browser settings.

      article
        h2.text-2xl.font-semibold.text-gray-900 Contact
        p.mt-2.text-gray-700
          | Privacy concerns can be shared at
          a.ml-1.text-teal-700(class="hover:underline" href="mailto:privacy@sarkariworld.com") privacy@sarkariworld.com