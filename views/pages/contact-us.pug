extends ../layouts/main

block content
  section.py-12.bg-gradient-to-r.from-teal-50.to-blue-50
    .max-w-4xl.mx-auto.px-4
      h1.text-4xl.font-bold.text-gray-900 Contact Us
      p.mt-3.text-gray-700 Reach out for support, feedback, or correction requests.

  section.py-12.bg-white
    .max-w-4xl.mx-auto.px-4
      .grid.gap-6(class="md:grid-cols-2")
        .rounded-lg.border.border-green-200.bg-green-50.p-6
          h2.text-xl.font-semibold.text-gray-900 WhatsApp
          p.mt-2.text-gray-700 Fastest way to contact our team.
          a.mt-4.inline-block.rounded.bg-green-600.px-4.py-2.font-semibold.text-white(href="https://wa.me/919122102491" target="_blank" rel="noopener noreferrer") Chat on WhatsApp

        .rounded-lg.border.border-red-200.bg-red-50.p-6
          h2.text-xl.font-semibold.text-gray-900 YouTube
          p.mt-2.text-gray-700 Follow us for update videos and notices.
          a.mt-4.inline-block.rounded.bg-red-600.px-4.py-2.font-semibold.text-white(href="https://www.youtube.com/@sarkari_world" target="_blank" rel="noopener noreferrer") Visit Channel

      .mt-8.rounded-lg.border-l-4.border-yellow-500.bg-yellow-50.p-6
        p.text-gray-800
          strong Note:
          |  Sarkari World is an independent information platform and does not charge for job selection.