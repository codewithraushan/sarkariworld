extends ../layouts/main

block content
  // Recent Update Section
  section.max-w-6xl.mx-auto.px-4.py-10
    .border.rounded-lg.shadow-sm.overflow-hidden

      // Header
      .bg-red-600.text-white.font-bold.px-4.py-3
        | Recent Updates Notification 🔥

      // Cards
      .grid.grid-cols-1.gap-4.p-4(class="md:grid-cols-2 lg:grid-cols-3")
        if recentPosts && recentPosts.length
          each post in recentPosts
            .group.flex.h-full.flex-col.rounded-2xl.border.border-gray-200.bg-white.p-4.shadow-sm.transition(class='hover:-translate-y-1 hover:shadow-lg')
              .flex.items-start.justify-between.gap-3
                if post.category === 'job'
                  span(class='inline-flex items-center rounded-full bg-blue-100 px-2.5 py-1 text-xs font-semibold text-blue-700') Job
                else if post.category === 'result'
                  span(class='inline-flex items-center rounded-full bg-green-100 px-2.5 py-1 text-xs font-semibold text-green-700') Result
                else if post.category === 'admit-card'
                  span(class='inline-flex items-center rounded-full bg-orange-100 px-2.5 py-1 text-xs font-semibold text-orange-700') Admit Card
                else if post.category === 'answer-key'
                  span(class='inline-flex items-center rounded-full bg-purple-100 px-2.5 py-1 text-xs font-semibold text-purple-700') Answer Key
                else if post.category === 'syllabus'
                  span(class='inline-flex items-center rounded-full bg-indigo-100 px-2.5 py-1 text-xs font-semibold text-indigo-700') Syllabus
                else if post.category === 'admission'
                  span(class='inline-flex items-center rounded-full bg-teal-100 px-2.5 py-1 text-xs font-semibold text-teal-700') Admission
                else
                  span(class='inline-flex items-center rounded-full bg-slate-100 px-2.5 py-1 text-xs font-semibold text-slate-700')= post.category
              h3.mt-3.text-base.font-semibold.leading-6.text-slate-900= post.title
              .mt-4.flex.items-center.justify-between.gap-3
                a.inline-flex.items-center.gap-1.text-sm.font-semibold.text-blue-600.underline.decoration-blue-500.decoration-2.underline-offset-4.transition(class='hover:text-blue-700 hover:decoration-blue-700' href='/' + post.slug) View Details
        else
          .rounded-2xl.border.border-dashed.border-gray-300.bg-gray-50.p-6.text-center.text-gray-600
            | No updates available yet.

      


  // Cards Section
  section.max-w-6xl.mx-auto.px-4.py-10
    .grid.gap-6(class="md:grid-cols-2 lg:grid-cols-3")
      each section in categorySections
        .border.rounded-lg.overflow-hidden.shadow-sm
          if section.accent === 'blue'
            .bg-blue-600.text-white.font-bold.px-4.py-2= section.title
          else if section.accent === 'green'
            .bg-green-600.text-white.font-bold.px-4.py-2= section.title
          else if section.accent === 'orange'
            .bg-orange-600.text-white.font-bold.px-4.py-2= section.title
          else if section.accent === 'purple'
            .bg-purple-600.text-white.font-bold.px-4.py-2= section.title
          else if section.accent === 'indigo'
            .bg-indigo-600.text-white.font-bold.px-4.py-2= section.title
          else if section.accent === 'teal'
            .bg-teal-600.text-white.font-bold.px-4.py-2= section.title
          else if section.accent === 'red'
            .bg-red-600.text-white.font-bold.px-4.py-2= section.title
          else
            .bg-slate-600.text-white.font-bold.px-4.py-2= section.title

          ul.p-4.space-y-2.text-sm
            if section.items && section.items.length
              each item in section.items
                li.flex.flex-col.gap-3.rounded-xl.border.border-gray-100.bg-white.p-3.transition(class='sm:flex-row sm:items-center sm:justify-between hover:border-gray-200 hover:shadow-sm')
                  .flex.flex-wrap.items-center.gap-2
                    if section.accent === 'blue'
                      a(class='text-slate-900 font-medium hover:text-blue-600' href='/' + item.slug)= item.title
                      a(class='inline-flex items-center rounded-full border border-blue-200 bg-blue-50 px-2.5 py-1 text-xs font-semibold text-blue-700 transition hover:border-blue-300 hover:bg-blue-100' href='/' + item.slug) View Details
                    else if section.accent === 'green'
                      a(class='text-slate-900 font-medium hover:text-green-600' href='/' + item.slug)= item.title
                      a(class='inline-flex items-center rounded-full border border-green-200 bg-green-50 px-2.5 py-1 text-xs font-semibold text-green-700 transition hover:border-green-300 hover:bg-green-100' href='/' + item.slug) View Details
                    else if section.accent === 'orange'
                      a(class='text-slate-900 font-medium hover:text-orange-600' href='/' + item.slug)= item.title
                      a(class='inline-flex items-center rounded-full border border-orange-200 bg-orange-50 px-2.5 py-1 text-xs font-semibold text-orange-700 transition hover:border-orange-300 hover:bg-orange-100' href='/' + item.slug) View Details
                    else if section.accent === 'purple'
                      a(class='text-slate-900 font-medium hover:text-purple-600' href='/' + item.slug)= item.title
                      a(class='inline-flex items-center rounded-full border border-purple-200 bg-purple-50 px-2.5 py-1 text-xs font-semibold text-purple-700 transition hover:border-purple-300 hover:bg-purple-100' href='/' + item.slug) View Details
                    else if section.accent === 'indigo'
                      a(class='text-slate-900 font-medium hover:text-indigo-600' href='/' + item.slug)= item.title
                      a(class='inline-flex items-center rounded-full border border-indigo-200 bg-indigo-50 px-2.5 py-1 text-xs font-semibold text-indigo-700 transition hover:border-indigo-300 hover:bg-indigo-100' href='/' + item.slug) View Details
                    else if section.accent === 'teal'
                      a(class='text-slate-900 font-medium hover:text-teal-600' href='/' + item.slug)= item.title
                      a(class='inline-flex items-center rounded-full border border-teal-200 bg-teal-50 px-2.5 py-1 text-xs font-semibold text-teal-700 transition hover:border-teal-300 hover:bg-teal-100' href='/' + item.slug) View Details
                    else if section.accent === 'red'
                      a(class='text-slate-900 font-medium hover:text-red-600' href='/' + item.slug)= item.title
                      a(class='inline-flex items-center rounded-full border border-red-200 bg-red-50 px-2.5 py-1 text-xs font-semibold text-red-700 transition hover:border-red-300 hover:bg-red-100' href='/' + item.slug) View Details
                    else
                      a(class='text-slate-900 font-medium hover:text-slate-600' href='/' + item.slug)= item.title
                      a(class='inline-flex items-center rounded-full border border-slate-200 bg-slate-50 px-2.5 py-1 text-xs font-semibold text-slate-700 transition hover:border-slate-300 hover:bg-slate-100' href='/' + item.slug) View Details
            else
              li.text-gray-500 No posts available.

            li
              if section.accent === 'blue'
                a.inline-flex.items-center.justify-center.w-full.rounded-lg.bg-blue-600.px-4.py-2.text-sm.font-semibold.text-white.shadow-sm.transition(class='hover:bg-blue-700 hover:shadow-md' href='/' + section.category) View All Posts
              else if section.accent === 'green'
                a.inline-flex.items-center.justify-center.w-full.rounded-lg.bg-green-600.px-4.py-2.text-sm.font-semibold.text-white.shadow-sm.transition(class='hover:bg-green-700 hover:shadow-md' href='/' + section.category) View All Posts
              else if section.accent === 'orange'
                a.inline-flex.items-center.justify-center.w-full.rounded-lg.bg-orange-600.px-4.py-2.text-sm.font-semibold.text-white.shadow-sm.transition(class='hover:bg-orange-700 hover:shadow-md' href='/' + section.category) View All Posts
              else
                a.inline-flex.items-center.justify-center.w-full.rounded-lg.bg-slate-700.px-4.py-2.text-sm.font-semibold.text-white.shadow-sm.transition(class='hover:bg-slate-800 hover:shadow-md' href='/' + section.category) View All Posts


  // Subscription Section
  section.bg-orange-50.border-y
    .max-w-6xl.mx-auto.px-4.py-12.text-center
      h2.text-2xl.font-bold.text-gray-800(class="md:text-3xl") Get Instant Job Alerts 🚀
      p.mt-3.text-gray-600.text-sm(class="md:text-base")
        | Subscribe to receive latest government job, admit card and result updates directly in
        | your inbox.

      if subscribeMessage
        if subscribeStatus === '1'
          p.mt-4.text-sm.font-semibold.text-green-700= subscribeMessage
        else if subscribeStatus === '0'
          p.mt-4.text-sm.font-semibold.text-red-700= subscribeMessage

      form.mt-6.max-w-3xl.mx-auto(action="/subscribe" method="POST")
        .grid.grid-cols-1.gap-3(class="md:grid-cols-2")
          input.w-full.px-4.py-3.rounded-lg.border(
            class="focus:outline-none focus:ring-2 focus:ring-orange-500"
            type="text"
            name="name"
            required
            placeholder="Full name *"
            autocomplete="name"
          )
          input.w-full.px-4.py-3.rounded-lg.border(
            class="focus:outline-none focus:ring-2 focus:ring-orange-500"
            type="email"
            name="email"
            required
            placeholder="Email address *"
            autocomplete="email"
          )
          input.w-full.px-4.py-3.rounded-lg.border(
            class="focus:outline-none focus:ring-2 focus:ring-orange-500"
            type="tel"
            name="mobile"
            placeholder="Mobile number"
            autocomplete="tel"
          )
          input.w-full.px-4.py-3.rounded-lg.border(
            class="focus:outline-none focus:ring-2 focus:ring-orange-500"
            type="text"
            name="city"
            placeholder="City"
            autocomplete="address-level2"
          )
          input.w-full.px-4.py-3.rounded-lg.border(
            class="focus:outline-none focus:ring-2 focus:ring-orange-500"
            type="text"
            name="state"
            placeholder="State"
            autocomplete="address-level1"
          )

        button.mt-4.bg-orange-600.text-white.px-6.py-3.rounded-lg.font-semibold.transition(class="hover:bg-orange-700" type="submit")
          | Subscribe

      p.text-xs.text-gray-500.mt-4 No spam. You can unsubscribe anytime.


  // FAQ Section
  section.py-16.bg-gray-50(class="md:py-24")
    .max-w-4xl.mx-auto.px-4
      h2.text-3xl.font-bold.text-center.mb-12.text-gray-900(class="md:text-4xl") Frequently Asked Questions

      .space-y-4

        details.bg-white.rounded-lg.p-6.cursor-pointer.border.border-gray-200
          summary.font-bold.text-lg.text-gray-900.flex.justify-between.items-center
            | What are the best government jobs for graduates?
            span +
          p.mt-4.text-gray-700
            | Popular government jobs for graduates include Banking (SBI, IBPS), SSC (CGL,
            | CHSL), Railways (RRB), and UPSC positions. Each offers excellent career growth
            | and benefits.

        details.bg-white.rounded-lg.p-6.cursor-pointer.border.border-gray-200
          summary.font-bold.text-lg.text-gray-900.flex.justify-between.items-center
            | How do I prepare for government job exams?
            span +
          p.mt-4.text-gray-700
            | Start by understanding the exam pattern and syllabus. Practice with previous
            | year papers, take mock tests, and stay updated with current affairs. We provide
            | all necessary resources on our platform.

        details.bg-white.rounded-lg.p-6.cursor-pointer.border.border-gray-200
          summary.font-bold.text-lg.text-gray-900.flex.justify-between.items-center
            | How often are new jobs posted?
            span +
          p.mt-4.text-gray-700
            | New government job notifications are posted regularly throughout the year. We
            | update our website daily with the latest opportunities and exam notifications.

        details.bg-white.rounded-lg.p-6.cursor-pointer.border.border-gray-200
          summary.font-bold.text-lg.text-gray-900.flex.justify-between.items-center
            | Can I get notifications for specific job categories?
            span +
          p.mt-4.text-gray-700
            | Yes, you can customize your notifications based on job categories, exam names,
            | and locations. Subscribe to our alerts to never miss an opportunity.