{
	"root": true,
	"env": {
		"node": true,
		"es2022": true
	},
	"extends": ["eslint:recommended", "plugin:import/recommended", "plugin:prettier/recommended"],
	"parserOptions": {
		"ecmaVersion": "latest",
		"sourceType": "module"
	},
	"settings": {
		"import/resolver": {
			"node": {
				"extensions": [".js", ".mjs", ".cjs"]
			}
		}
	},
	"rules": {
		"no-console": [
			"warn",
			{
				"allow": ["warn", "error"]
			}
		],
		"import/order": [
			"warn",
			{
				"alphabetize": {
					"order": "asc",
					"caseInsensitive": true
				},
				"groups": [["builtin", "external"], "internal", "parent", "sibling", "index"],
				"newlines-between": "always"
			}
		]
	},
	"overrides": [
		{
			"files": ["test/**/*", "test1/**/*", "tests/**/*", "**/__tests__/**/*"],
			"env": {
				"node": true
			},
			"globals": {
				"describe": "readonly",
				"it": "readonly",
				"test": "readonly",
				"before": "readonly",
				"after": "readonly",
				"beforeEach": "readonly",
				"afterEach": "readonly"
			}
		},
		{
			"files": ["**/*.ejs"],
			"rules": {
				"prettier/prettier": "error"
			}
		}
	]
}
